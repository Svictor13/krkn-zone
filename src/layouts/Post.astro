---
import Base from './Base.astro';

interface Props {
  title: string;
  date: Date;
  excerpt: string;
  image?: string;
  section: string;
  sectionLabel: string;
  sectionPath: string;
}

const { title, date, excerpt, image, section, sectionLabel, sectionPath } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<Base title={title} description={excerpt} image={image}>
  {image && (
    <img
      src={image}
      alt={title}
      class="post-anchor-image"
    />
  )}

  <div class="container">
    <div class="post-header">
      <div class="post-header__section">
        <a href={sectionPath}>{sectionLabel}</a>
      </div>
      <h1 class="post-header__title">{title}</h1>
      <div class="post-header__date">{formattedDate}</div>
    </div>

    <article class="post-body">
      <slot />
      <div class="post-signature">✒️♟️</div>
    </article>
  </div>
</Base>

<style>
  .post-header__section a {
    color: var(--orange);
    text-decoration: none;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
  }

  .post-header__section a:hover {
    text-decoration: underline;
  }
</style>
