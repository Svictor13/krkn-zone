---
// HUD Full-Bleed Layout — no max-width shell, used for the Today dashboard
import '../styles/hud.css';
import '../styles/today.css';

interface Props {
  title?: string;
}

const { title = 'KRKN HUD' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#0a0a0f" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
    <style>
      html, body { background: #0a0a0f; color: #e8e8f0; height: 100%; }
      body { margin: 0; }
    </style>
  </head>
  <body class="hud-body hud-body--full">
    <div class="hud-today-wrap">
      <slot />
    </div>
  </body>
</html>
