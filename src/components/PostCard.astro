---
interface Props {
  title: string;
  date: Date;
  excerpt: string;
  image?: string;
  slug: string;
  section: string;
  sectionLabel: string;
}

const { title, date, excerpt, image, slug, section, sectionLabel } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const href = `/${section}/${slug}`;
---

<article class="post-card">
  <a href={href} tabindex="-1" aria-hidden="true">
    {image
      ? <img src={image} alt={title} class="post-card__image" loading="lazy" />
      : <div class="post-card__image--placeholder" />
    }
  </a>
  <div class="post-card__body">
    <div class="post-card__meta">
      <span>{sectionLabel}</span> &nbsp;·&nbsp; {formattedDate}
    </div>
    <h3 class="post-card__title">
      <a href={href}>{title}</a>
    </h3>
    <p class="post-card__excerpt">{excerpt}</p>
  </div>
</article>
