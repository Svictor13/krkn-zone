---
import Base from '../layouts/Base.astro';

const topics = [
  {
    cat: 'Exposure Management',
    title: 'CTEM',
    desc: 'Continuous Threat Exposure Management — finding and fixing the exposures that give attackers their foothold, before they become an incident.',
  },
  {
    cat: 'Architecture',
    title: 'Zero Trust',
    desc: 'Assume breach, limit blast radius, and connect identity, access, and segmentation to the exposures that actually matter.',
  },
  {
    cat: 'Measurement',
    title: 'Risk Quantification',
    desc: 'Measuring exposure reduction instead of activity — so security spend maps to outcomes a board can understand.',
  },
  {
    cat: 'Operations',
    title: 'Autonomous Security',
    desc: "Letting AI handle the 98% that's noise so your people focus on the 2% that's signal — autonomous, not unattended.",
  },
  {
    cat: 'Field Intelligence',
    title: 'Latin America & Global Risk',
    desc: 'Lessons from operating across eight countries and both sides of the water, where threat models rarely match the textbook.',
  },
  {
    cat: 'Remediation',
    title: 'Closing the Gap',
    desc: 'The remediation gap nobody talks about — strategy that turns findings into fixes instead of an ever-growing backlog.',
  },
];
---

<Base
  title="About"
  description="26 years. 8 countries. Both sides of the water. Stefan Wieczorek on cybersecurity, risk, and what it means to think like a Kraken."
>
  <div class="hero hero--center">
    <span class="eyebrow">About · KRKN</span>
    <h1 class="hero__tagline">To understand what sinks ships, you have to think like <em>the thing in the water.</em></h1>
    <p class="hero__sub">I'm Stefan Wieczorek — and KRKN is where 26 years of cybersecurity strategy, risk quantification, and field intelligence get written down.</p>
    <div class="hero__actions">
      <a href="/charts" class="btn btn--primary">Read the Charts →</a>
    </div>
  </div>

  <div class="stat-band">
    <div class="stat">
      <div class="stat__figure">26</div>
      <div class="stat__label">Years in the field</div>
    </div>
    <div class="stat">
      <div class="stat__figure">8</div>
      <div class="stat__label">Countries worked across</div>
    </div>
    <div class="stat">
      <div class="stat__figure">Both</div>
      <div class="stat__label">Sides of the water</div>
    </div>
  </div>

  <div class="container">
    <div class="section-header">
      <div class="section-header__label">About</div>
      <h2 class="section-header__title">26 years. 8 countries. Both sides of the water.</h2>
    </div>

    <div class="about-body">
      <p>
        I'm Stefan Wieczorek. For 26 years I've worked at the intersection of technology, risk, and the realities of operating across eight countries — both sides of the water, from Latin America to global enterprise.
      </p>

      <p>
        KRKN is where that experience gets written down. It's not vendor marketing and it's not theory for its own sake. It's field intelligence: cybersecurity strategy grounded in what actually sinks organizations versus what merely sounds dangerous in a slide deck.
      </p>

      <p>
        The Kraken metaphor isn't decoration. To protect ships, you have to think like the thing in the water — understand the exposures, the blast radius, and the gap between activity and outcomes. That perspective runs through everything published here.
      </p>
    </div>
  </div>

  <div class="container--wide">
    <div class="section-header">
      <div class="section-header__label">What KRKN Covers</div>
    </div>

    <div class="cover-grid">
      {topics.map(topic => (
        <article class="cover-card">
          <div class="cover-card__cat">{topic.cat}</div>
          <h3 class="cover-card__title">{topic.title}</h3>
          <p class="cover-card__desc">{topic.desc}</p>
        </article>
      ))}
    </div>
  </div>

  <div class="closing-cta">
    <h2>Think like a Kraken.</h2>
    <p class="closing-cta__text">
      New field intelligence on CTEM, Zero Trust, and risk quantification — written for people who'd rather prevent the breach than measure the activity.
    </p>
    <div class="closing-cta__actions">
      <a href="/charts" class="btn btn--primary">Read the Charts →</a>
      <a href="https://www.linkedin.com/in/stefanwieczorek/" target="_blank" rel="noopener" class="btn btn--ghost">Connect on LinkedIn →</a>
    </div>
  </div>
</Base>
